msgid "the key to search for"
msgstr "το κλειδί προς αναζήτηση"

#: dnf/cli/commands/repoquery.py:297
msgid ""
"Option '--resolve' has to be used together with one of the '--conflicts', '--"
"depends', '--enhances', '--provides', '--recommends', '--requires', '--"
"requires-pre', '--suggests' or '--supplements' options"
msgstr ""
"Η επιλογή '--resolve' πρέπει να χρησιμοποιείται μαζί με μία από τις επιλογές "
"'--conflicts', '--depends', '--enhances', '--provides', '--recommends', '--"
"requires', '--requires-pre', '--suggests' ή '--supplements'"

#: dnf/cli/commands/repoquery.py:307
msgid ""
"Option '--recursive' has to be used with '--whatrequires <REQ>' (optionally "
"with '--alldeps', but not with '--exactdeps'), or with '--requires <REQ> --"
"resolve'"
msgstr ""
"Η επιλογή '--recursive' πρέπει να χρησιμοποιείται με το '--whatrequires "
"<REQ>' (προαιρετικά με το '--alldeps', αλλά όχι με το '--exactdeps'), ή με "
"το '--requires <REQ> --resolve'"

