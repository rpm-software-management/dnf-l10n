#: dnf/base.py:1819
#, python-format
msgid "Adding packages from group '%s': %s"
msgstr "Προσθήκη πακέτων από την ομάδα '%s': %s"

#: dnf/base.py:1842 dnf/cli/cli.py:283 dnf/cli/commands/__init__.py:439
#: dnf/cli/commands/__init__.py:496 dnf/cli/commands/__init__.py:589
#: dnf/cli/commands/__init__.py:638 dnf/cli/commands/install.py:84
#: dnf/cli/commands/install.py:107 dnf/cli/commands/install.py:114
msgid "Nothing to do."
msgstr "Καμία ενέργεια προς εκτέλεση."

#: dnf/base.py:1860
msgid "No groups marked for removal."
msgstr "Δεν έχουν σημειωθεί ομάδες για αφαίρεση."

#: dnf/base.py:1894
msgid "No group marked for upgrade."
msgstr "Δεν έχει σημειωθεί ομάδα για αναβάθμιση."

#: dnf/base.py:2117
#, python-format
msgid "Package %s not installed, cannot downgrade it."
msgstr "Το πακέτο %s δεν είναι εγκατεστημένο, αδυναμία υποβάθμισής του."

#: dnf/base.py:2119 dnf/base.py:2138 dnf/base.py:2151 dnf/base.py:2182
#: dnf/base.py:2252 dnf/base.py:2260 dnf/base.py:2280 dnf/base.py:2416
#: dnf/cli/cli.py:487 dnf/cli/commands/__init__.py:422
#: dnf/cli/commands/__init__.py:479 dnf/cli/commands/__init__.py:583
#: dnf/cli/commands/__init__.py:630 dnf/cli/commands/__init__.py:708
#: dnf/cli/commands/install.py:151 dnf/cli/commands/reinstall.py:69
#: dnf/cli/commands/reinstall.py:83 dnf/cli/commands/upgrade.py:109
#: dnf/cli/commands/upgrade.py:120
#, python-format
msgid "No match for argument: %s"
msgstr "Δεν βρέθηκε αντιστοιχία για την παράμετρο: %s"

#: dnf/base.py:2126
#, python-format
msgid "Package %s of lower version already installed, cannot downgrade it."
msgstr ""
"Μια παλαιότερη έκδοση του %s είναι ήδη εγκατεστημένη, αδυναμία υποβάθμισης."

#: dnf/base.py:2149
#, python-format
msgid "Package %s not installed, cannot reinstall it."
msgstr "Το πακέτο %s δεν είναι εγκατεστημένο, αδυναμία επανεγκατάστασής του."

#: dnf/base.py:2164
#, python-format
msgid "File %s is a source package and cannot be updated, ignoring."
msgstr ""
"Το αρχείο %s είναι πακέτο πηγαίου κώδικα και δεν μπορεί να ενημερωθεί, "
"αγνόηση."

#: dnf/base.py:2179
#, python-format
msgid "Package %s not installed, cannot update it."
msgstr "Το πακέτο %s δεν είναι εγκατεστημένο, αδυναμία ενημέρωσής του."

#: dnf/base.py:2189
#, python-format
msgid ""
"The same or higher version of %s is already installed, cannot update it."
msgstr ""
"Η ίδια ή μεταγενέστερη έκδοση του %s είναι ήδη εγκατεστημένη, αδυναμία "
"ενημέρωσης."

#: dnf/base.py:2249 dnf/cli/commands/reinstall.py:80
#, python-format
msgid "Package %s available, but not installed."
msgstr "Το πακέτο %s είναι διαθέσιμο, αλλά όχι εγκατεστημένο."

#: dnf/base.py:2255
#, python-format
msgid "Package %s available, but installed for different architecture."
msgstr ""
"Το πακέτο %s είναι διαθέσιμο, αλλά εγκατεστημένο για διαφορετική "
"αρχιτεκτονική."

#: dnf/base.py:2298 dnf/cli/commands/install.py:140
#: dnf/cli/commands/remove.py:132
#, python-format
msgid "Not a valid form: %s"
msgstr "Μη έγκυρη μορφή: %s"

#: dnf/base.py:2313 dnf/cli/commands/__init__.py:678
#: dnf/cli/commands/remove.py:161
msgid "No packages marked for removal."
msgstr "Δεν έχουν σημειωθεί πακέτα για αφαίρεση."

#: dnf/base.py:2323
#, python-format
msgid ""
"Unneeded protected package: %s (and its dependencies) cannot be removed, "
"either mark it as user-installed or change protected_packages configuration "
"option."
msgstr ""
"Περιττό προστατευμένο πακέτο: το %s (και οι εξαρτήσεις του) δεν μπορεί να "
"αφαιρεθεί, είτε σημειώστε το ως εγκατεστημένο από τον χρήστη είτε αλλάξτε "
"την επιλογή ρύθμισης protected_packages."

#: dnf/base.py:2423 dnf/cli/cli.py:498
#, python-format
msgid "Packages for argument %s available, but not installed."
msgstr "Διαθέσιμα πακέτα για την παράμετρο %s, αλλά όχι εγκατεστημένα."

#: dnf/base.py:2428
#, python-format
msgid "Package %s of lowest version already installed, cannot downgrade it."
msgstr ""
"Η χαμηλότερη έκδοση του πακέτου %s είναι ήδη εγκατεστημένη, αδυναμία "
"υποβάθμισης."

#: dnf/base.py:2528
msgid "No security updates needed, but {} update available"
msgstr ""
"Δεν απαιτούνται ενημερώσεις ασφαλείας, αλλά {} ενημέρωση είναι διαθέσιμη"

#: dnf/base.py:2530
msgid "No security updates needed, but {} updates available"
msgstr ""
"Δεν απαιτούνται ενημερώσεις ασφαλείας, αλλά {} ενημερώσεις είναι διαθέσιμες"

#: dnf/base.py:2534
msgid "No security updates needed for \"{}\", but {} update available"
msgstr ""
"Δεν απαιτούνται ενημερώσεις ασφαλείας για το \"{}\", αλλά {} ενημέρωση είναι "
"διαθέσιμη"

#: dnf/base.py:2536
msgid "No security updates needed for \"{}\", but {} updates available"
msgstr ""
"Δεν απαιτούνται ενημερώσεις ασφαλείας για το \"{}\", αλλά {} ενημερώσεις "
"είναι διαθέσιμες"

#. raise an exception, because po.repoid is not in self.repos
#: dnf/base.py:2557
#, python-format
msgid "Unable to retrieve a key for a commandline package: %s"
msgstr "Αδυναμία ανάκτησης κλειδιού για πακέτο γραμμής εντολών: %s"

#: dnf/base.py:2565
#, python-format
msgid ". Failing package is: %s"
msgstr ". Το πακέτο που αποτυγχάνει είναι: %s"

#: dnf/base.py:2566
#, python-format
msgid "GPG Keys are configured as: %s"
msgstr "Τα κλειδιά GPG έχουν ρυθμιστεί ως: %s"

#: dnf/base.py:2578
#, python-format
msgid "GPG key at %s (0x%s) is already installed"
msgstr "Το κλειδί GPG στο %s (0x%s) είναι ήδη εγκατεστημένο"

#: dnf/base.py:2614
msgid "The key has been approved."
msgstr "Το κλειδί εγκρίθηκε."

#: dnf/base.py:2617
msgid "The key has been rejected."
msgstr "Το κλειδί απορρίφθηκε."

#: dnf/base.py:2650
#, python-format
msgid "Key import failed (code %d)"
msgstr "Η εισαγωγή κλειδιού απέτυχε (κωδικός %d)"

#: dnf/base.py:2652
msgid "Key imported successfully"
msgstr "Το κλειδί εισήχθη επιτυχώς"

#: dnf/base.py:2656
msgid "Didn't install any keys"
msgstr "Δεν εγκαταστάθηκαν κλειδιά"

#: dnf/base.py:2659
#, python-format
msgid ""
"The GPG keys listed for the \"%s\" repository are already installed but they "
"are not correct for this package.\n"
"Check that the correct key URLs are configured for this repository."
msgstr ""
"Τα κλειδιά GPG που αναφέρονται για το αποθετήριο \"%s\" είναι ήδη "
"εγκατεστημένα, αλλά δεν είναι τα σωστά για αυτό το πακέτο.\n"
"Ελέγξτε αν έχουν ρυθμιστεί τα σωστά URL κλειδιών για αυτό το αποθετήριο."

#: dnf/base.py:2670
msgid "Import of key(s) didn't help, wrong key(s)?"
msgstr "Η εισαγωγή των κλειδιών δεν βοήθησε, μήπως είναι λάθος τα κλειδιά;"

#: dnf/base.py:2723
msgid "  * Maybe you meant: {}"
msgstr ""

#: dnf/base.py:2755
msgid "Package \"{}\" from local repository \"{}\" has incorrect checksum"
msgstr ""
"Το πακέτο \"{}\" από το τοπικό αποθετήριο \"{}\" έχει εσφαλμένο άθροισμα "
"ελέγχου"

#: dnf/base.py:2758
msgid "Some packages from local repository have incorrect checksum"
msgstr ""
"Ορισμένα πακέτα από το τοπικό αποθετήριο έχουν εσφαλμένο άθροισμα ελέγχου"

#: dnf/base.py:2761
msgid "Package \"{}\" from repository \"{}\" has incorrect checksum"
msgstr ""
"Το πακέτο \"{}\" από το αποθετήριο \"{}\" έχει εσφαλμένο άθροισμα ελέγχου"

#: dnf/base.py:2764
msgid ""
"Some packages have invalid cache, but cannot be downloaded due to \"--"
"cacheonly\" option"
msgstr ""
"Ορισμένα πακέτα έχουν μη έγκυρη προσωρινή μνήμη, αλλά δεν είναι δυνατή η "
"λήψη τους λόγω της επιλογής \"--cacheonly\""

#: dnf/base.py:2782 dnf/base.py:2802
msgid "No match for argument"
msgstr "Δεν βρέθηκε αντιστοιχία για την παράμετρο"

#: dnf/base.py:2790 dnf/base.py:2810
msgid "All matches were filtered out by exclude filtering for argument"
msgstr ""
"Όλες οι αντιστοιχίες αποκλείστηκαν από το φιλτράρισμα εξαιρέσεων για την "
"παράμετρο"

#: dnf/base.py:2792
msgid "All matches were filtered out by modular filtering for argument"
msgstr ""
"Όλες οι αντιστοιχίες αποκλείστηκαν από το αρθρωτό φιλτράρισμα για την "
"παράμετρο"

#: dnf/base.py:2808
msgid "All matches were installed from a different repository for argument"
msgstr ""
