msgid_plural "Sleep for {} seconds"
msgstr[0] "Κοίμηση για {} δευτερόλεπτο"
msgstr[1] "Κοίμηση για {} δευτερόλεπτα"

#: dnf/automatic/main.py:342
msgid "System is off-line."
msgstr "Το σύστημα είναι εκτός σύνδεσης."

