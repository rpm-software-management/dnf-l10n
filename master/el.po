msgid "Display capabilities that the package conflicts with."
msgstr "Εμφάνιση δυνατοτήτων με τις οποίες συγκρούεται το πακέτο."

#: dnf/cli/commands/repoquery.py:236
msgid ""
"Display capabilities that the package can depend on, enhance, recommend, "
"suggest, and supplement."
msgstr ""
"Εμφάνιση δυνατοτήτων από τις οποίες μπορεί να εξαρτάται, να βελτιώνει, να "
"συνιστά, να προτείνει και να συμπληρώνει το πακέτο."

