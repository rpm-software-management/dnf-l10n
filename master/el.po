msgstr "Σφάλμα:%s"

#: dnf/base.py:151 dnf/base.py:492 dnf/base.py:494
msgid "loading repo '{}' failure: {}"
msgstr "Αποτυχία φόρτωσης του αποθετηρίου '{}': {}"

#: dnf/base.py:153
msgid "Loading repository '{}' has failed"
msgstr "Αποτυχία φόρτωσης του αποθετηρίου '{}'"

#: dnf/base.py:341
msgid "Metadata timer caching disabled when running on metered connection."
msgstr ""
"Η χρονομετρημένη προσωρινή αποθήκευση μεταδεδομένων απενεργοποιήθηκε λόγω "
"σύνδεσης με χρέωση."

#: dnf/base.py:346
msgid "Metadata timer caching disabled when running on a battery."
msgstr ""
"Η χρονομετρημένη προσωρινή αποθήκευση μεταδεδομένων απενεργοποιήθηκε λόγω "
"λειτουργίας με μπαταρία."

#: dnf/base.py:351
msgid "Metadata timer caching disabled."
msgstr "Η χρονομετρημένη προσωρινή αποθήκευση μεταδεδομένων απενεργοποιήθηκε."

#: dnf/base.py:356
msgid "Metadata cache refreshed recently."
msgstr "Η προσωρινή μνήμη μεταδεδομένων ανανεώθηκε πρόσφατα."

#: dnf/base.py:362 dnf/cli/commands/__init__.py:90
msgid "There are no enabled repositories in \"{}\"."
msgstr "Δεν υπάρχουν ενεργοποιημένα αποθετήρια στο \"{}\"."

#: dnf/base.py:369
#, python-format
msgid "%s: will never be expired and will not be refreshed."
msgstr "%s: δεν θα λήξει ποτέ και δεν θα ανανεωθεί."

#: dnf/base.py:371
#, python-format
msgid "%s: has expired and will be refreshed."
msgstr "%s: έχει λήξει και θα ανανεωθεί."

#. expires within the checking period:
#: dnf/base.py:375
#, python-format
msgid "%s: metadata will expire after %d seconds and will be refreshed now"
msgstr ""
"%s: τα μεταδεδομένα θα λήξουν μετά από %d δευτερόλεπτα και θα ανανεωθούν τώρα"

#: dnf/base.py:379
#, python-format
msgid "%s: will expire after %d seconds."
msgstr "%s: θα λήξει μετά από %d δευτερόλεπτα."

#. performs the md sync
#: dnf/base.py:385
msgid "Metadata cache created."
msgstr "Η προσωρινή μνήμη μεταδεδομένων δημιουργήθηκε."

#: dnf/base.py:418 dnf/base.py:486
#, python-format
msgid "%s: using metadata from %s."
msgstr "%s: χρήση μεταδεδομένων από %s."

#: dnf/base.py:430 dnf/base.py:499
#, python-format
msgid "Ignoring repositories: %s"
msgstr "Αγνόηση αποθετηρίων: %s"

#: dnf/base.py:433
#, python-format
msgid "Last metadata expiration check: %s ago on %s."
msgstr "Τελευταίος έλεγχος λήξης μεταδεδομένων: πριν από %s στις %s."

#: dnf/base.py:527
msgid ""
"The downloaded packages were saved in cache until the next successful "
"transaction."
msgstr ""
"Τα ληφθέντα πακέτα αποθηκεύτηκαν στην προσωρινή μνήμη μέχρι την επόμενη "
"επιτυχή συναλλαγή."

#: dnf/base.py:529
#, python-format
msgid "You can remove cached packages by executing '%s'."
msgstr ""
"Μπορείτε να αφαιρέσετε τα πακέτα από την προσωρινή μνήμη εκτελώντας '%s'."

#: dnf/base.py:662
#, python-format
msgid "Invalid tsflag in config file: %s"
msgstr "Μη έγκυρο tsflag στο αρχείο ρυθμίσεων: %s"

#: dnf/base.py:720
#, python-format
msgid "Failed to add groups file for repository: %s - %s"
msgstr "Αποτυχία προσθήκης αρχείου ομάδων για το αποθετήριο: %s - %s"

#: dnf/base.py:984
msgid "Running transaction check"
msgstr "Εκτέλεση ελέγχου συναλλαγής"

#: dnf/base.py:992
msgid "Error: transaction check vs depsolve:"
msgstr "Σφάλμα: έλεγχος συναλλαγής έναντι επίλυσης εξαρτήσεων:"

#: dnf/base.py:998
msgid "Transaction check succeeded."
msgstr "Ο έλεγχος συναλλαγής πέτυχε."

#: dnf/base.py:1001
msgid "Running transaction test"
msgstr "Εκτέλεση δοκιμής συναλλαγής"

#: dnf/base.py:1011 dnf/base.py:1163
msgid "RPM: {}"
msgstr "RPM: {}"

#: dnf/base.py:1012
msgid "Transaction test error:"
msgstr "Σφάλμα δοκιμής συναλλαγής:"

#: dnf/base.py:1023
msgid "Transaction test succeeded."
msgstr "Η δοκιμή συναλλαγής πέτυχε."

#: dnf/base.py:1044
msgid "Running transaction"
msgstr "Εκτέλεση συναλλαγής"

#: dnf/base.py:1081
msgid "Disk Requirements:"
msgstr "Απαιτήσεις Δίσκου:"

#: dnf/base.py:1084
#, python-brace-format
msgid "At least {0}MB more space needed on the {1} filesystem."
msgid_plural "At least {0}MB more space needed on the {1} filesystem."
msgstr[0] ""
"Απαιτούνται τουλάχιστον {0}MB επιπλέον χώρου στο σύστημα αρχείων {1}."
msgstr[1] ""
"Απαιτούνται τουλάχιστον {0}MB επιπλέον χώρου στο σύστημα αρχείων {1}."

#: dnf/base.py:1091
msgid "Error Summary"
msgstr "Σύνοψη Σφαλμάτων"

#: dnf/base.py:1117
#, python-brace-format
msgid "RPMDB altered outside of {prog}."
msgstr "Η βάση δεδομένων RPM (RPMDB) τροποποιήθηκε εκτός του {prog}."

#: dnf/base.py:1164 dnf/base.py:1172
msgid "Could not run transaction."
msgstr "Αδυναμία εκτέλεσης συναλλαγής."

#: dnf/base.py:1167
msgid "Transaction couldn't start:"
msgstr "Η συναλλαγή δεν μπόρεσε να ξεκινήσει:"

#: dnf/base.py:1181
#, python-format
msgid "Failed to remove transaction file %s"
msgstr "Αποτυχία αφαίρεσης του αρχείου συναλλαγής %s"

#: dnf/base.py:1263
msgid "Some packages were not downloaded. Retrying."
msgstr "Ορισμένα πακέτα δεν ελήφθησαν. Επανάληψη προσπάθειας."

#: dnf/base.py:1293
#, python-format
msgid "Delta RPMs reduced %.1f MB of updates to %.1f MB (%.1f%% saved)"
msgstr "Τα Delta RPM μείωσαν τα %.1f MB ενημερώσεων σε %.1f MB (κέρδος %.1f%%)"

#: dnf/base.py:1297
#, python-format
msgid ""
"Failed Delta RPMs increased %.1f MB of updates to %.1f MB (%.1f%% wasted)"
msgstr ""
"Τα αποτυχημένα Delta RPM αύξησαν τα %.1f MB ενημερώσεων σε %.1f MB (απώλεια "
"%.1f%%)"

#: dnf/base.py:1342
msgid "Cannot add local packages, because transaction job already exists"
msgstr ""
"Αδυναμία προσθήκης τοπικών πακέτων, επειδή υπάρχει ήδη εργασία συναλλαγής"

#: dnf/base.py:1356
msgid "Could not open: {}"
msgstr "Αδυναμία ανοίγματος: {}"

#: dnf/base.py:1394
#, python-format
msgid "Public key for %s is not installed"
msgstr "Το δημόσιο κλειδί για το %s δεν είναι εγκατεστημένο"

#: dnf/base.py:1398
#, python-format
msgid "Problem opening package %s"
msgstr "Πρόβλημα κατά το άνοιγμα του πακέτου %s"

#: dnf/base.py:1406
#, python-format
msgid "Public key for %s is not trusted"
msgstr "Το δημόσιο κλειδί για το %s δεν είναι έμπιστο"

#: dnf/base.py:1410
#, python-format
msgid "Package %s is not signed"
msgstr "Το πακέτο %s δεν είναι υπογεγραμμένο"

#: dnf/base.py:1440
#, python-format
msgid "Cannot remove %s"
msgstr "Αδυναμία αφαίρεσης του %s"

#: dnf/base.py:1444
#, python-format
msgid "%s removed"
msgstr "Το %s αφαιρέθηκε"

#: dnf/base.py:1737
msgid "No match for group package \"{}\""
