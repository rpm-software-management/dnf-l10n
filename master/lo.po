#: dnf/cli/commands/repoquery.py:241
msgid "Display capabilities that the package depends on."
msgstr "ສະແດງຄວາມສາມາດທີ່ແພັກເກດນີ້ຕ້ອງໃຊ້."

#: dnf/cli/commands/repoquery.py:242
#, python-format
msgid ""
"If the package is not installed display capabilities that it depends on for "
"running %%pre and %%post scriptlets. If the package is installed display "
"capabilities that is depends for %%pre, %%post, %%preun and %%postun."
msgstr ""
"ຫາກແພັກເກດຍັງບໍ່ໄດ້ຕິດຕັ້ງ ໃຫ້ສະແດງຄວາມສາມາດທີ່ມັນຕ້ອງໃຊ້ເພື່ອຣັນ %%pre ແລະ %%post "
"scriptlets. ຫາກແພັກເກດຕິດຕັ້ງແລ້ວ ໃຫ້ສະແດງຄວາມສາມາດທີ່ມັນຕ້ອງໃຊ້ສຳລັບ %%pre, %%post, "
"%%preun ແລະ %%postun."

#: dnf/cli/commands/repoquery.py:245
msgid "Display capabilities that the package suggests."
msgstr "ສະແດງຄວາມສາມາດທີ່ແພັກເກດນີ້ສະເໜີແນະ."

#: dnf/cli/commands/repoquery.py:246
msgid "Display capabilities that the package can supplement."
msgstr "ສະແດງຄວາມສາມາດທີ່ແພັກເກດນີ້ສາມາດເພີ່ມເຕີມໃຫ້ໄດ້."

#: dnf/cli/commands/repoquery.py:252
msgid "Display only available packages."
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ມີໃຫ້ໃຊ້."

#: dnf/cli/commands/repoquery.py:255
msgid "Display only installed packages."
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ຕິດຕັ້ງແລ້ວ."

#: dnf/cli/commands/repoquery.py:256
msgid ""
"Display only packages that are not present in any of available repositories."
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ບໍ່ມີຢູ່ໃນຄັງເກັບໃດໆທີ່ມີຢູ່."

#: dnf/cli/commands/repoquery.py:257
msgid ""
"Display only packages that provide an upgrade for some already installed "
"package."
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ມີເວີຊັນອັບເກຣດສຳລັບແພັກເກດທີ່ຕິດຕັ້ງແລ້ວ."

#: dnf/cli/commands/repoquery.py:258
#, python-brace-format
msgid ""
"Display only packages that can be removed by \"{prog} autoremove\" command."
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ສາມາດລຶບອອກໄດ້ດ້ວຍຄຳສັ່ງ \"{prog} autoremove\"."

#: dnf/cli/commands/repoquery.py:260
msgid "Display only packages that were installed by user."
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ຕິດຕັ້ງໂດຍຜູ້ໃຊ້."

#: dnf/cli/commands/repoquery.py:272
msgid "Display only recently edited packages"
msgstr "ສະແດງສະເພາະແພັກເກດທີ່ຫາກໍ່ຖືກແກ້ໄຂເມື່ອບໍ່ດົນມານີ້"

#: dnf/cli/commands/repoquery.py:275
msgid "the key to search for"
msgstr "ຄຳຄົ້ນຫາ (key) ທີ່ຈະຄົ້ນຫາ"

#: dnf/cli/commands/repoquery.py:297
msgid ""
"Option '--resolve' has to be used together with one of the '--conflicts', '--"
"depends', '--enhances', '--provides', '--recommends', '--requires', '--"
"requires-pre', '--suggests' or '--supplements' options"
msgstr ""
"ຕ້ອງໃຊ້ຕົວເລືອກ '--resolve' ຮ່ວມກັບຕົວເລືອກ '--conflicts', '--depends', '--"
"enhances', '--provides', '--recommends', '--requires', '--requires-pre', '--"
"suggests' ຫຼື '--supplements' ຕົວໃດຕົວໜຶ່ງ"

#: dnf/cli/commands/repoquery.py:307
msgid ""
"Option '--recursive' has to be used with '--whatrequires <REQ>' (optionally "
"with '--alldeps', but not with '--exactdeps'), or with '--requires <REQ> --"
"resolve'"
msgstr ""
"ຕ້ອງໃຊ້ຕົວເລືອກ '--recursive' ຮ່ວມກັບ '--whatrequires <REQ>' (ຫຼື '--alldeps' ນຳກໍໄດ້, "
"ແຕ່ຫ້າມໃຊ້ຮ່ວມກັບ '--exactdeps'), ຫຼື ໃຊ້ຮ່ວມກັບ '--requires <REQ> --resolve'"

#: dnf/cli/commands/repoquery.py:314
#, python-brace-format
msgid "argument {} requires --whatrequires or --whatdepends option"
msgstr "ອາຄິວເມນ {} ຕ້ອງການຕົວເລືອກ --whatrequires ຫຼື --whatdepends"

